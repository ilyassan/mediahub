{
  "info": {
    "name": "MEDIAHUB - Streaming Backend Platform",
    "_postman_id": "mediahub-collection-v1",
    "description": "Complete API collection for MEDIAHUB. All requests go through the API Gateway on port 8080. The gateway routes /api/users/** → user-service, /api/media/** → media-service, /api/subscriptions/** → subscription-service.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" }
  ],
  "item": [
    {
      "name": "User Service",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": ["{{base_url}}"],
              "path": ["api", "users"]
            }
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/1",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "1"]
            }
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Martin\",\n  \"email\": \"alice@example.com\",\n  \"role\": \"USER\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": ["{{base_url}}"],
              "path": ["api", "users"]
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Updated\",\n  \"email\": \"alice.updated@example.com\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/1",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "1"]
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/1",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "1"]
            }
          }
        },
        {
          "name": "Get User Subscription (Feign → subscription-service)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/1/subscription",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "1", "subscription"]
            }
          }
        },
        {
          "name": "Get Available Media (WebClient → media-service)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/media",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "media"]
            }
          }
        },
        {
          "name": "Add to Viewing History",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mediaId\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/1/history",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "1", "history"]
            }
          }
        },
        {
          "name": "Get Viewing History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/1/history",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "1", "history"]
            }
          }
        }
      ]
    },
    {
      "name": "Media Service",
      "item": [
        {
          "name": "Get All Media (no filter)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/media?page=0&size=10",
              "host": ["{{base_url}}"],
              "path": ["api", "media"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get All Media (filter by genre)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/media?genre=Action&page=0&size=10",
              "host": ["{{base_url}}"],
              "path": ["api", "media"],
              "query": [
                { "key": "genre", "value": "Action" },
                { "key": "page",  "value": "0" },
                { "key": "size",  "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get All Media (filter by category)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/media?category=Movies&page=0&size=10",
              "host": ["{{base_url}}"],
              "path": ["api", "media"],
              "query": [
                { "key": "category", "value": "Movies" },
                { "key": "page",     "value": "0" },
                { "key": "size",     "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get All Media (filter by genre + category)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/media?genre=Action&category=Movies&page=0&size=10",
              "host": ["{{base_url}}"],
              "path": ["api", "media"],
              "query": [
                { "key": "genre",    "value": "Action" },
                { "key": "category", "value": "Movies" },
                { "key": "page",     "value": "0" },
                { "key": "size",     "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Media By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/media/1",
              "host": ["{{base_url}}"],
              "path": ["api", "media", "1"]
            }
          }
        },
        {
          "name": "Create Media",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Inception\",\n  \"description\": \"A thief who steals corporate secrets through dream-sharing technology.\",\n  \"type\": \"FILM\",\n  \"genre\": \"Sci-Fi\",\n  \"category\": \"Movies\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/media",
              "host": ["{{base_url}}"],
              "path": ["api", "media"]
            }
          }
        },
        {
          "name": "Update Media (partial)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Inception - Director's Cut\",\n  \"genre\": \"Thriller\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/media/1",
              "host": ["{{base_url}}"],
              "path": ["api", "media", "1"]
            }
          }
        },
        {
          "name": "Delete Media",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/media/1",
              "host": ["{{base_url}}"],
              "path": ["api", "media", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Subscription Service",
      "item": [
        {
          "name": "Create Subscription",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"plan\": \"PREMIUM\",\n  \"startDate\": \"2025-01-01\",\n  \"endDate\": \"2026-01-01\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/subscriptions",
              "host": ["{{base_url}}"],
              "path": ["api", "subscriptions"]
            }
          }
        },
        {
          "name": "Get Subscription By User ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/subscriptions/user/1",
              "host": ["{{base_url}}"],
              "path": ["api", "subscriptions", "user", "1"]
            }
          }
        },
        {
          "name": "Get Media Details via Subscription (Feign → media-service)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/subscriptions/media/1",
              "host": ["{{base_url}}"],
              "path": ["api", "subscriptions", "media", "1"]
            }
          }
        }
      ]
    }
  ]
}
